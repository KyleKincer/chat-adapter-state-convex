{
  "name": "chat-adapter-state-convex",
  "version": "0.1.0",
  "description": "Convex state adapter component for Vercel Chat SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KyleKincer/chat-adapter-state-convex.git"
  },
  "homepage": "https://github.com/KyleKincer/chat-adapter-state-convex#readme",
  "bugs": {
    "url": "https://github.com/KyleKincer/chat-adapter-state-convex/issues"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chat",
    "chat-sdk",
    "convex",
    "state-adapter",
    "state",
    "component"
  ],
  "files": [
    "dist",
    "src/component",
    "!src/component/**/*.test.ts",
    "src/shared.ts",
    "src/test.ts"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./test": "./src/test.ts",
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "import": "./dist/component/convex.config.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "import": "./dist/component/convex.config.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist .convex *.tsbuildinfo",
    "codegen": "convex codegen --component-dir ./src/component",
    "dev": "tsc --project ./tsconfig.build.json --watch --preserveWatchOutput",
    "build": "tsc --project ./tsconfig.build.json",
    "build:clean": "rm -rf dist *.tsbuildinfo && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --typecheck",
    "test:watch": "vitest --typecheck --clearScreen false",
    "test:coverage": "vitest run --coverage --coverage.reporter=text",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test"
  },
  "dependencies": {
    "chat": "4.25.0"
  },
  "peerDependencies": {
    "convex": "^1.32.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@vitest/coverage-v8": "^4.1.2",
    "convex": "^1.32.0",
    "convex-test": "^0.0.47",
    "typescript": "^5.9.2",
    "vite": "^7.1.10",
    "vitest": "^4.1.2"
  }
}
